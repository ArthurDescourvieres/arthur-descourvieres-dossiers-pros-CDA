{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "docker compose -f ../docker-compose.test.yml up -d --wait && vitest run --config vitest.integration.config.ts",
    "test:integration:down": "docker compose -f ../docker-compose.test.yml down",
    "test:coverage": "docker compose -f ../docker-compose.test.yml up -d --wait && vitest run --config vitest.coverage.config.ts --coverage",
    "test:coverage:down": "docker compose -f ../docker-compose.test.yml down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "purge": "tsx src/jobs/purge-deactivated.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@prisma/client": "^7.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "file-type": "^22.0.1",
    "hono": "^4.12.26",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "ws": "^8.21.0"
  }
}
