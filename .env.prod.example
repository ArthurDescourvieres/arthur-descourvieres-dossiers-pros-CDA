# Production environment for docker-compose.prod.yml.
#
# On the VPS, copy this file to `.env` next to docker-compose.prod.yml, fill
# every value, and lock it down: `chmod 600 .env`.
# The real `.env` is git-ignored and must NEVER be committed — only this
# example is versioned.

# --- Container images (immutable tags) --------------------------------------
# The deploy workflow overrides these with the commit-SHA tag it just pushed.
BACKEND_IMAGE=ghcr.io/arthurdescourvieres/arthur-descourvieres-dossiers-pros-cda-backend:latest
WEB_IMAGE=ghcr.io/arthurdescourvieres/arthur-descourvieres-dossiers-pros-cda-web:latest

# --- Public domain / TLS (Let's Encrypt via Caddy) --------------------------
DOMAIN=memo.derroce.com
ACME_EMAIL=derroceftn@gmail.com
# Static CDA quiz served on its own subdomain by the same Caddy (cda-quiz/site).
QUIZ_DOMAIN=quiz.derroce.com

# --- Application secrets -----------------------------------------------------
# Generate JWT_SECRET with e.g. `openssl rand -base64 48`.
JWT_SECRET=__GENERATE_A_LONG_RANDOM_STRING__
CORS_ORIGINS=https://memo.derroce.com

# --- Transactional email (Brevo SMTP) ---------------------------------------
# 1. In Brevo, create an SMTP key: "SMTP & API" → "SMTP" tab.
# 2. Authenticate the domain derroce.com in Brevo and add the DKIM/SPF/DMARC DNS
#    records (see the invite-email setup notes) so mail isn't flagged as spam.
# SMTP_USER is the SMTP login Brevo shows on that page; SMTP_KEY is the SMTP key.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=__YOUR_BREVO_SMTP_LOGIN__
SMTP_KEY=__YOUR_BREVO_SMTP_KEY__
MAIL_FROM="Memo <noreply@derroce.com>"
# Base URL used to build the invitation link in the e-mail.
APP_URL=https://memo.derroce.com

# --- PostgreSQL --------------------------------------------------------------
# Two roles (defense in depth, § moindre privilège):
#   - the OWNER (POSTGRES_USER) owns the schema and runs migrations (DDL);
#   - the APP role (APP_DB_USER) is created at first init by
#     infra/postgres/init/10-app-role.sh and can only SELECT/INSERT/UPDATE/DELETE
#     — it has no CREATE/ALTER/DROP, so the running API can never alter the schema.
POSTGRES_USER=memo
POSTGRES_PASSWORD=__STRONG_OWNER_PASSWORD__
POSTGRES_DB=memo
APP_DB_USER=memo_app
APP_DB_PASSWORD=__STRONG_APP_PASSWORD__

# The API connects as the least-privilege app role (host = internal service `db`).
DATABASE_URL=postgresql://memo_app:__STRONG_APP_PASSWORD__@db:5432/memo
# The one-shot `migrate` service connects as the owner (DDL allowed).
MIGRATE_DATABASE_URL=postgresql://memo:__STRONG_OWNER_PASSWORD__@db:5432/memo

# --- Backups (infra/backup/backup.sh → Hetzner Storage Box) ------------------
# Symmetric key used to GPG-encrypt every artifact before it leaves the VPS.
BACKUP_PASSPHRASE=__LONG_RANDOM_BACKUP_PASSPHRASE__
STORAGE_BOX_USER=u123456
STORAGE_BOX_HOST=u123456.your-storagebox.de
STORAGE_BOX_PORT=23
STORAGE_BOX_PATH=backups/memo
RETENTION_DAYS=14
