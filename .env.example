# App
NODE_ENV=development
JWT_SECRET=change_me_in_production_use_a_long_random_string

# Database
# Choose a strong password. Keep POSTGRES_PASSWORD raw, but percent-encode any
# URL-reserved characters in DATABASE_URL (e.g. ' -> %27, @ -> %40, : -> %3A).
DATABASE_URL="postgresql://memo:change_me_strong_password@db:5432/memo"
POSTGRES_USER=memo
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=memo

# Redis
REDIS_URL=redis://redis:6379

# Frontend (Vite proxy target — use service name inside Docker)
API_URL=http://api:3000

# Frontend public env (exposed to the browser)
VITE_API_URL=http://localhost:3000
